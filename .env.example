PROJECT_NAME="MeetMind AI"
VERSION="1.0.0"
DATABASE_URL="sqlite:///./meeting.db"
OPENAI_API_KEY=""
OPENAI_TRANSCRIPTION_MODEL="gpt-4o-mini-transcribe"
OPENAI_ANALYSIS_MODEL="gpt-4o-mini"
OPENAI_REQUEST_TIMEOUT_SECONDS=120
TRANSCRIPTION_MAX_RETRIES=3
MAX_TOKENS_PER_CHUNK=6000
MAX_CHUNK_CHARACTERS=24000
CHUNK_OVERLAP_SIZE=800
ENABLE_SMART_CHUNKING=true
CHAT_MODEL="gpt-4o-mini"
MAX_CHAT_HISTORY=10
MAX_CONTEXT_LENGTH=30000
CHAT_TEMPERATURE=0.2
PDF_INCLUDE_TRANSCRIPT=false
PDF_INCLUDE_CHAT_HISTORY=true
EXPORT_BRANDING="Generated by MeetMind AI"
DEFAULT_EXPORT_FORMAT="pdf"
FFMPEG_BINARY="ffmpeg"
FFPROBE_BINARY="ffprobe"
MAX_AUDIO_DURATION_SECONDS=7200
SECRET_KEY="change-me-before-production"
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM="HS256"
UPLOAD_DIRECTORY="app/uploads"
MAX_UPLOAD_SIZE=524288000
LOG_LEVEL="INFO"
ENVIRONMENT="development"
ALLOWED_ORIGINS="*"
MAX_REQUEST_SIZE=524288000
REQUEST_TIMEOUT=120
ENABLE_DEBUG=false
ENABLE_DOCS=true
SECURITY_HEADERS=true
TRUSTED_HOSTS="*"
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
